# SHACL shape for the PMDCo/OBI MeasurementDevice pattern.
#
# Validates:
#   1. Device node (obi:OBI_0000968)
#      - must have rdfs:label
#      - must have dcterms:conformsTo
#      - serial_number (if present) must be a string
#      - calibration_date (if present) must be xsd:date

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix obi:     <http://purl.obolibrary.org/obo/OBI_> .
@prefix schema:  <https://schema.org/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix shape:   <https://w3id.org/pmd/co/shapes/measurement-device/> .
@base            <https://w3id.org/pmd/co/shapes/measurement-device/> .

shape:measurement_device
    a sh:NodeShape ;
    sh:targetClass obi:0000968 ;   # Device
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A Device must declare dcterms:conformsTo pointing to the versioned schema IRI." ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A Device must have exactly one rdfs:label." ;
    ] ;
    sh:property [
        sh:path schema:manufacturer ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "manufacturer must be a plain string." ;
    ] ;
    sh:property [
        sh:path schema:model ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "model must be a plain string." ;
    ] ;
    sh:property [
        sh:path schema:serialNumber ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "serial_number must be a plain string." ;
    ] ;
    sh:property [
        sh:path dcterms:date ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
        sh:message "calibration_date must be an xsd:date value (YYYY-MM-DD)." ;
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .
