# SHACL shape for the PMDCo Chemical Composition pattern.
# Source: https://github.com/materialdigital/core-ontology/tree/main/patterns/chemical%20composition
# Reworked after hackathon 2025 (Miro frame 351).
#
# NOTE: This shape is designed for use with RDFS/OWL reasoning.
# Without reasoning, sh:targetClass constraints on subclasses
# (e.g. MassProportion as subclass of Proportion, specific element
# types as subclasses of PMD_0020140) will not fire automatically.

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix obo:     <http://purl.obolibrary.org/obo/> .
@prefix pmd:     <https://w3id.org/pmd/co/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix shape:   <https://w3id.org/pmd/co/shapes/chemical_composition/> .
@prefix :        <https://w3id.org/pmd/co/shapes/chemical_composition/> .
@base            <https://w3id.org/pmd/co/shapes/chemical_composition/> .

shape:material_label
    a sh:NodeShape ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "The material linked via quality_of must have an rdfs:label." ;
    ] .

shape:chemical_composition
    a sh:NodeShape ;
    sh:targetClass  pmd:PMD_0000551 ;  # ChemicalComposition
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A ChemicalComposition instance must declare dcterms:conformsTo pointing to the versioned schema IRI." ;
    ] ;
    sh:property [
        sh:path obo:RO_0000080 ;       # quality_of
        sh:nodeKind sh:BlankNodeOrIRI ; # blank node (labelled material) or full IRI both accepted
        sh:minCount 1 ;
        sh:node shape:material_label ;
        sh:message "ChemicalComposition must have a quality_of link to a Material with an rdfs:label." ;
    ] ;
    sh:property [
        sh:path pmd:PMD_0000004 ;      # is_subject_of
        sh:node shape:chemical_composition_specification ;
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .

shape:chemical_composition_specification
    rdf:type sh:NodeShape ;
    sh:description "An instance of ChemicalCompositionSpecification has at least one member instance of FractionValueSpecification." ;
    sh:targetClass pmd:PMD_0025002 ;   # ChemicalCompositionSpecification
    sh:property [
        sh:path obo:RO_0002351 ;       # has_member
        sh:node shape:fraction_value_specification ;
        sh:minCount 1 ;
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .

shape:fraction_value_specification
    rdf:type sh:NodeShape ;
    sh:description "A FractionValueSpecification must carry a numeric value in [0,100] and one of the three allowed unit IRIs." ;
    sh:targetClass pmd:PMD_0025997 ;   # FractionValueSpecification
    sh:property [
        sh:path obo:OBI_0001937 ;      # has_specified_numeric_value
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Fraction value must be a number between 0 and 100." ;
    ] ;
    sh:property [
        sh:path obo:IAO_0000039 ;      # has_measurement_unit_label
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( <http://purl.obolibrary.org/obo/UO_0000163>
                <http://purl.obolibrary.org/obo/UO_0000164>
                <http://purl.obolibrary.org/obo/UO_0000165> ) ;
        sh:message "Unit must be UO_0000163 (mass%), UO_0000164 (vol%), or UO_0000165 (mol%)." ;
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .

shape:proportion
    rdf:type sh:NodeShape ;
    sh:description "An instance of Proportion (mass/molar/volume) is specified by exactly one FractionValueSpecification and has a relational quality of a portion of matter." ;
    sh:targetClass pmd:PMD_0020101 ;   # Proportion (superclass; MassProportion requires reasoning)
    sh:property [
        sh:path pmd:PMD_0000077 ;      # specified_by_value
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:node shape:fraction_value_specification ;
    ] ;
    sh:property [
        sh:path pmd:PMD_0025999 ;      # relational_quality_of
        sh:minCount 1 ;
        sh:class pmd:PMD_0000001 ;     # PortionOfMatter
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .

shape:pure_substance_chemical_element
    rdf:type sh:NodeShape ;
    sh:description "An instance of PortionOfChemicalElement has a relational quality (Proportion) and is part of a material." ;
    sh:targetClass pmd:PMD_0020140 ;   # PortionOfSingleChemicalElement (superclass; specific elements require reasoning)
    sh:property [
        sh:path pmd:PMD_0025998 ;      # has_relational_quality
        sh:node shape:proportion ;
    ] ;
    sh:property [
        sh:path obo:BFO_0000050 ;      # part_of
        sh:class pmd:PMD_0000000 ;     # Material
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .
