{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.simplified.json",
  "title": "Chemical Composition — BWMD (Simplified Input)",
  "description": "A user-friendly form to describe the chemical composition of a material using the BWMD ontology. Provide a label, the balance element, and the weight fractions of each alloying element.",
  "type": "object",
  "required": ["label", "base_element", "fractions"],
  "additionalProperties": false,
  "properties": {
    "label": {
      "title": "Label",
      "description": "Human-readable name for this composition. Example: '316L Chemical Composition', 'AlSi10Mg powder (batch A)'.",
      "type": "string",
      "minLength": 1,
      "examples": ["316L Chemical Composition", "AlSi10Mg powder batch A"]
    },
    "base_element": {
      "title": "Base Element",
      "description": "The balance or majority element of the alloy (e.g. 'Fe' for steel, 'Al' for aluminium alloys). Only one base element per composition.",
      "type": "object",
      "required": ["symbol"],
      "additionalProperties": false,
      "properties": {
        "symbol": {
          "title": "Element Symbol",
          "description": "IUPAC symbol of the balance element.",
          "type": "string",
          "enum": [
            "H",  "He", "Li", "Be", "B",  "C",  "N",  "O",  "F",  "Ne",
            "Na", "Mg", "Al", "Si", "P",  "S",  "Cl", "Ar", "K",  "Ca",
            "Sc", "Ti", "V",  "Cr", "Mn", "Fe", "Co", "Ni", "Cu", "Zn",
            "Ga", "Ge", "As", "Se", "Br", "Kr", "Rb", "Sr", "Y",  "Zr",
            "Nb", "Mo", "Tc", "Ru", "Rh", "Pd", "Ag", "Cd", "In", "Sn",
            "Sb", "Te", "I",  "Xe", "Cs", "Ba", "La", "Ce", "Pr", "Nd",
            "Pm", "Sm", "Eu", "Gd", "Tb", "Dy", "Ho", "Er", "Tm", "Yb",
            "Lu", "Hf", "Ta", "W",  "Re", "Os", "Ir", "Pt", "Au", "Hg",
            "Tl", "Pb", "Bi", "Po", "At", "Rn", "Fr", "Ra", "Ac", "Th",
            "Pa", "U",  "Np", "Pu", "Am", "Cm", "Bk", "Cf", "Es", "Fm",
            "Md", "No", "Lr", "Rf", "Db", "Sg", "Bh", "Hs", "Mt", "Ds",
            "Rg", "Cn", "Nh", "Fl", "Mc", "Lv", "Ts", "Og"
          ]
        }
      }
    },
    "fractions": {
      "title": "Weight Fractions",
      "description": "Weight fractions of the alloying elements. Add one entry per element. Use the same unit for all entries.",
      "type": "array",
      "minItems": 1,
      "items": {
        "title": "Weight Fraction",
        "type": "object",
        "required": ["symbol", "min_value", "max_value"],
        "additionalProperties": false,
        "properties": {
          "symbol": {
            "title": "Element Symbol",
            "description": "IUPAC symbol of the alloying element.",
            "type": "string",
            "enum": [
              "H",  "He", "Li", "Be", "B",  "C",  "N",  "O",  "F",  "Ne",
              "Na", "Mg", "Al", "Si", "P",  "S",  "Cl", "Ar", "K",  "Ca",
              "Sc", "Ti", "V",  "Cr", "Mn", "Fe", "Co", "Ni", "Cu", "Zn",
              "Ga", "Ge", "As", "Se", "Br", "Kr", "Rb", "Sr", "Y",  "Zr",
              "Nb", "Mo", "Tc", "Ru", "Rh", "Pd", "Ag", "Cd", "In", "Sn",
              "Sb", "Te", "I",  "Xe", "Cs", "Ba", "La", "Ce", "Pr", "Nd",
              "Pm", "Sm", "Eu", "Gd", "Tb", "Dy", "Ho", "Er", "Tm", "Yb",
              "Lu", "Hf", "Ta", "W",  "Re", "Os", "Ir", "Pt", "Au", "Hg",
              "Tl", "Pb", "Bi", "Po", "At", "Rn", "Fr", "Ra", "Ac", "Th",
              "Pa", "U",  "Np", "Pu", "Am", "Cm", "Bk", "Cf", "Es", "Fm",
              "Md", "No", "Lr", "Rf", "Db", "Sg", "Bh", "Hs", "Mt", "Ds",
              "Rg", "Cn", "Nh", "Fl", "Mc", "Lv", "Ts", "Og"
            ]
          },
          "min_value": {
            "title": "Minimum Value",
            "description": "Minimum weight fraction [0–100]. For an exact (point) value, set min_value = max_value.",
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "max_value": {
            "title": "Maximum Value",
            "description": "Maximum weight fraction [0–100]. For an exact (point) value, set min_value = max_value.",
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "unit": {
            "title": "Unit",
            "description": "Unit of the weight fraction. '%' and 'wt.%' denote weight percentage; 'at.%' denotes atomic percentage.",
            "type": "string",
            "enum": ["%", "wt.%", "at.%"],
            "default": "wt.%"
          }
        }
      }
    }
  },
  "examples": [
    {
      "label": "316L Chemical Composition",
      "base_element": { "symbol": "Fe" },
      "fractions": [
        { "symbol": "Cr", "min_value": 16.0, "max_value": 18.0, "unit": "wt.%" },
        { "symbol": "Ni", "min_value": 10.0, "max_value": 14.0, "unit": "wt.%" },
        { "symbol": "Mo", "min_value": 2.0,  "max_value": 3.0,  "unit": "wt.%" },
        { "symbol": "Mn", "min_value": 0.0,  "max_value": 2.0,  "unit": "wt.%" },
        { "symbol": "Si", "min_value": 0.0,  "max_value": 0.75, "unit": "wt.%" },
        { "symbol": "C",  "min_value": 0.0,  "max_value": 0.03, "unit": "wt.%" }
      ]
    }
  ]
}
