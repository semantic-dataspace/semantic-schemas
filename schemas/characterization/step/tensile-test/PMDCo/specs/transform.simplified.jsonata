(
  /*
   * Tensile Test (PMDCo measurement pattern) — simplified JSON → OO-LD JSON
   *
   * Input fields (see schema.simplified.json):
   *   test_name         string   required
   *   specimen_iri      string   required — IRI of the specimen node
   *   test_id           string   optional, derived from test_name if omitted
   *   description       string   optional
   *   test_standard     string   optional
   *   strain_rate       number   optional
   *   strain_rate_unit  string   optional, default "1/s"
   *   temperature       number   optional (°C)
   *   gauge_length      number   optional
   *   gauge_length_unit string   optional, default "mm"
   *   preload           number   optional
   *   preload_unit      string   optional, default "MPa"
   *   results           array    optional
   *     name            string   free-text property name (e.g. "Yield Strength")
   *     value           number
   *     unit            string   "MPa" | "GPa" | "%"
   */

  $schemaUri := "https://github.com/semantic-dataspace/semantic-schemas/tree/main/schemas/characterization/step/tensile-test/PMDCo/#v1.0.0";

  /* ── Unit label → QUDT unit IRI ──────────────────────────────────────── */
  $unitMap := {
    "MPa": "uqudt:MegaPascal",
    "GPa": "uqudt:GigaPascal",
    "%":   "uqudt:PERCENT"
  };

  /* ── Node IDs — capture input fields as $ variables so closures work ── */
  /* specimen_iri and test_name are document fields, not $ variables;       */
  /* capture them here so they resolve correctly inside $map callbacks.    */
  $specimenIri := specimen_iri;
  $slug        := $replace($lowercase($trim(test_name)), /[^a-z0-9]+/, "-");
  $testId      := $exists(test_id) ? test_id : "tensile-test-" & $slug;
  $roleId      := $testId & "-evaluant-role";

  /* ── Test conditions ──────────────────────────────────────────────────── */
  $conds := [];
  $conds := $exists(test_standard)
    ? $append($conds, [{
        "type": "pmdco:PMD_0000013",
        "id":   $testId & "-condition-standard",
        "parameter_label": "Test Standard",
        "parameter_unit":  test_standard
      }])
    : $conds;
  $conds := $exists(strain_rate)
    ? $append($conds, [{
        "type": "pmdco:PMD_0000013",
        "id":   $testId & "-condition-strain-rate",
        "parameter_label": "Strain Rate",
        "parameter_value": strain_rate,
        "parameter_unit":  $exists(strain_rate_unit) ? strain_rate_unit : "1/s"
      }])
    : $conds;
  $conds := $exists(temperature)
    ? $append($conds, [{
        "type": "pmdco:PMD_0000013",
        "id":   $testId & "-condition-temperature",
        "parameter_label": "Temperature",
        "parameter_value": temperature,
        "parameter_unit":  "°C"
      }])
    : $conds;
  $conds := $exists(gauge_length)
    ? $append($conds, [{
        "type": "pmdco:PMD_0000013",
        "id":   $testId & "-condition-gauge-length",
        "parameter_label": "Gauge Length",
        "parameter_value": gauge_length,
        "parameter_unit":  $exists(gauge_length_unit) ? gauge_length_unit : "mm"
      }])
    : $conds;
  $conds := $exists(preload)
    ? $append($conds, [{
        "type": "pmdco:PMD_0000013",
        "id":   $testId & "-condition-preload",
        "parameter_label": "Pre-load",
        "parameter_value": preload,
        "parameter_unit":  $exists(preload_unit) ? preload_unit : "MPa"
      }])
    : $conds;

  /* ── Measured results (full OBI measurement pattern) ─────────────────── */
  /* $specimenIri, $testId captured above as $ vars; closures resolve them. */
  /* The slug computation is inlined twice (datum/svs IDs, quality IRI)     */
  /* to avoid $ bindings inside the callback body, which this jsonata       */
  /* implementation does not support inside $map callbacks.                 */
  $measured := $exists(results) and $count(results) > 0
    ? $map(results, function($r, $i) {
        {
          "type":  "obo:IAO_0000109",
          "id":    $testId & "-result-" & $replace($lowercase($trim($r.name)), /[^a-z0-9]+/, "-") & "-smd",
          "label": $r.name,
          "is_about": $specimenIri,
          "is_quality_measurement_of": $specimenIri & "-quality-" & $replace($lowercase($trim($r.name)), /[^a-z0-9]+/, "-"),
          "has_value_spec": {
            "type":               "obo:OBI_0001931",
            "id":                 $testId & "-result-" & $replace($lowercase($trim($r.name)), /[^a-z0-9]+/, "-") & "-svs",
            "result_value":       $r.value,
            "result_unit":        $lookup($unitMap, $r.unit),
            "specifies_value_of": $specimenIri & "-quality-" & $replace($lowercase($trim($r.name)), /[^a-z0-9]+/, "-"),
            "is_about":           $specimenIri
          }
        }
      })
    : undefined;

  /* ── OO-LD output ─────────────────────────────────────────────────────── */
  $base := {
    "conforms_to":         $schemaUri,
    "type":                "pmdco:PMD_0000974",
    "id":                  $testId,
    "label":               test_name,
    "realizes":            [{"type": "obo:OBI_0000067", "id": $roleId, "realized_in": $testId}],
    "has_specified_input": [$specimenIri]
  };

  $withDate  := $exists(test_date)   ? $merge([$base,     {"date": test_date}])                  : $base;
  $withDesc  := $exists(description) ? $merge([$withDate, {"description": description}])         : $withDate;
  $withConds := $count($conds) > 0   ? $merge([$withDesc, {"has_process_attribute": $conds}])    : $withDesc;

  $exists($measured)
    ? $merge([$withConds, {"measured_properties": $measured}])
    : $withConds
)
