# SHACL shape for the PMDCo Characterization Step (OBI Assay) pattern.
#
# Sources:
#   - Input and Output of Processes
#     https://github.com/materialdigital/core-ontology/tree/main/patterns/input%20and%20output%20of%20processes
#   - Measurement
#     https://github.com/materialdigital/core-ontology/tree/main/patterns/measurement
#
# Validates the generic characterization step node only.
# Measured results are validated by specialised shape files
# (e.g. characterization/tensile-test/TTO/specs/shape.ttl).

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix obi:     <http://purl.obolibrary.org/obo/OBI_> .
@prefix bfo:     <http://purl.obolibrary.org/obo/BFO_> .
@prefix pmd:     <https://w3id.org/pmd/co/> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix shape:   <https://w3id.org/pmd/co/shapes/characterization/step/> .
@prefix :        <https://w3id.org/pmd/co/shapes/characterization/step/> .
@base            <https://w3id.org/pmd/co/shapes/characterization/step/> .

shape:assay
    a sh:NodeShape ;
    sh:targetClass <http://purl.obolibrary.org/obo/OBI_0000070> ;   # obi:Assay
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A CharacterizationStep must declare dcterms:conformsTo pointing to the versioned schema IRI." ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A CharacterizationStep must have exactly one rdfs:label." ;
    ] ;
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/OBI_0000293> ;   # has_specified_input
        sh:nodeKind sh:IRI ;
        sh:message "Each has_specified_input value must be an IRI referencing a specimen or material node." ;
    ] ;
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000062> ;   # preceded_by
        sh:nodeKind sh:IRI ;
        sh:message "Each preceded_by value must be an IRI referencing another characterization step." ;
    ] ;
    sh:property [
        sh:path pmd:PMD_0000016 ;   # has_process_condition
        sh:node shape:process_condition ;
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .

shape:process_condition
    a sh:NodeShape ;
    sh:targetClass pmd:PMD_0000013 ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A ProcessCondition must have exactly one rdfs:label." ;
    ] ;
    sh:property [
        sh:path qudt:value ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:message "ProcessCondition value must be an xsd:double." ;
    ] ;
    sh:property [
        sh:path qudt:hasUnit ;
        sh:maxCount 1 ;
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .
