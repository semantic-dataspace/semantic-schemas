# SHACL shape for the PMDCo ManufacturingProcess pattern.
#
# Source pattern: Input and Output of Processes
#   https://github.com/materialdigital/core-ontology/tree/main/patterns/input%20and%20output%20of%20processes
#
# Validates:
#   1. ManufacturingProcess node (PMD_0000029)
#      - must have rdfs:label
#      - must have dcterms:conformsTo
#      - inputs and outputs must be IRIs
#      - preceded_by references must be IRIs
#   2. ProcessCondition nodes (PMD_0000013)
#      - must have rdfs:label
#      - value (if present) must be xsd:double
#
# Note: Inputs/outputs reference materials that are independent knowledge-graph
# nodes. This shape does not attempt to validate their internal structure —
# load the appropriate material or specimen shape for that.

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix obi:     <http://purl.obolibrary.org/obo/OBI_> .
@prefix bfo:     <http://purl.obolibrary.org/obo/BFO_> .
@prefix pmd:     <https://w3id.org/pmd/co/> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix shape:   <https://w3id.org/pmd/co/shapes/manufacturing/step/> .
@prefix :        <https://w3id.org/pmd/co/shapes/manufacturing/step/> .
@base            <https://w3id.org/pmd/co/shapes/manufacturing/step/> .

# ── ManufacturingProcess node ─────────────────────────────────────────────────

shape:manufacturing_process
    a sh:NodeShape ;
    sh:targetClass pmd:PMD_0000029 ;   # ManufacturingProcess
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A ManufacturingProcess must declare dcterms:conformsTo pointing to the versioned schema IRI." ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A ManufacturingProcess must have exactly one rdfs:label." ;
    ] ;
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/OBI_0000293> ;   # has_specified_input
        sh:nodeKind sh:IRI ;
        sh:message "Each has_specified_input value must be an IRI referencing a material node." ;
    ] ;
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/OBI_0000299> ;   # has_specified_output
        sh:nodeKind sh:IRI ;
        sh:message "Each has_specified_output value must be an IRI referencing a material node." ;
    ] ;
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000062> ;   # preceded_by
        sh:nodeKind sh:IRI ;
        sh:message "Each preceded_by value must be an IRI referencing another process node." ;
    ] ;
    sh:property [
        sh:path pmd:PMD_0000016 ;   # has_process_condition
        sh:node shape:process_condition ;
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .

# ── ProcessCondition node ─────────────────────────────────────────────────────

shape:process_condition
    a sh:NodeShape ;
    sh:targetClass pmd:PMD_0000013 ;   # ProcessCondition
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A ProcessCondition must have exactly one rdfs:label (parameter name)." ;
    ] ;
    sh:property [
        sh:path qudt:value ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:message "ProcessCondition value must be an xsd:double." ;
    ] ;
    sh:property [
        sh:path qudt:hasUnit ;
        sh:maxCount 1 ;
        sh:message "ProcessCondition may have at most one unit." ;
    ] ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) .
